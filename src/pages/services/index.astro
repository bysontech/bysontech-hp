---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import { services } from '../../content/services';
---

<BaseLayout title="サービス" description="BysonTechが提供するWebシステム開発・業務効率化・クラウド導入支援のサービス一覧です。">
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4">
      <h1 class="text-3xl font-bold mb-4">サービス</h1>
      <p class="text-gray-600 mb-12">
        BysonTechでは、お客様のビジネス課題に合わせた3つのサービスを提供しています。
      </p>

      <div class="flex flex-col gap-10">
        {services.map((s) => (
          <div class="border border-gray-200 rounded-lg p-8">
            <h2 class="text-xl font-bold mb-3">{s.title}</h2>
            <p class="text-gray-600 mb-5">{s.description}</p>
            <ul class="flex flex-col gap-2">
              {s.features.map((f) => (
                <li class="flex items-start gap-2 text-sm text-gray-700">
                  <span class="text-blue-600 mt-0.5">✓</span>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
