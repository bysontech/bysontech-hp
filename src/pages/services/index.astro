---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import { services } from '../../content/services';

const pageTitle = 'サービス';
const pageDescription =
  'BysonTechが提供する2つのサービス：小規模DX向けPoC開発とPoCテンプレート販売の詳細をご覧ください。';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="max-w-5xl mx-auto px-4 py-14">
    <h1 class="text-3xl font-bold mb-2">サービス</h1>
    <p class="text-gray-500 mb-12">
      BysonTechは「PoC開発」と「テンプレート販売」の2つの形態でDX支援を行います。
    </p>

    {
      services.map((service) => (
        <section id={service.id} class="mb-16 scroll-mt-20">
          <h2 class="text-2xl font-bold mb-2">{service.name}</h2>
          <p class="text-gray-600 mb-6">{service.summary}</p>

          <div class="grid md:grid-cols-2 gap-6 mb-6">
            <div class="bg-gray-50 rounded-xl p-5">
              <h3 class="font-bold text-sm uppercase text-gray-400 mb-3">対象顧客</h3>
              <ul class="space-y-1">
                {service.targetCustomer.map((item) => (
                  <li class="text-sm text-gray-700 flex gap-2">
                    <span class="text-blue-500 mt-0.5">•</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div class="bg-gray-50 rounded-xl p-5">
              <h3 class="font-bold text-sm uppercase text-gray-400 mb-3">提供内容</h3>
              <ul class="space-y-1">
                {service.deliverables.map((item) => (
                  <li class="text-sm text-gray-700 flex gap-2">
                    <span class="text-green-500 mt-0.5">✓</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-6 mb-6">
            <div class="border border-green-200 rounded-xl p-5">
              <h3 class="font-bold text-green-700 mb-3">向いている人</h3>
              <ul class="space-y-1">
                {service.fitFor.map((item) => (
                  <li class="text-sm text-gray-700 flex gap-2">
                    <span class="text-green-500 mt-0.5">○</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div class="border border-red-200 rounded-xl p-5">
              <h3 class="font-bold text-red-700 mb-3">向いていない人</h3>
              <ul class="space-y-1">
                {service.notFitFor.map((item) => (
                  <li class="text-sm text-gray-700 flex gap-2">
                    <span class="text-red-400 mt-0.5">✕</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <div class="bg-blue-50 rounded-xl p-4 inline-block">
            <span class="text-sm text-gray-500">価格帯：</span>
            <span class="font-bold text-blue-700">{service.priceRange}</span>
          </div>
        </section>
      ))
    }

    <!-- Comparison -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">サービス比較</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-gray-100">
              <th class="text-left p-3 border border-gray-200"></th>
              {services.map((s) => (
                <th class="text-left p-3 border border-gray-200 font-bold">{s.name}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="p-3 border border-gray-200 text-gray-500">価格帯</td>
              {services.map((s) => (
                <td class="p-3 border border-gray-200">{s.priceRange}</td>
              ))}
            </tr>
            <tr class="bg-gray-50">
              <td class="p-3 border border-gray-200 text-gray-500">技術力の要件</td>
              <td class="p-3 border border-gray-200">不要（お任せ）</td>
              <td class="p-3 border border-gray-200">ある程度必要</td>
            </tr>
            <tr>
              <td class="p-3 border border-gray-200 text-gray-500">カスタマイズ</td>
              <td class="p-3 border border-gray-200">要件に応じて実装</td>
              <td class="p-3 border border-gray-200">限定対応（別途見積）</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="p-3 border border-gray-200 text-gray-500">保守・運用</td>
              <td class="p-3 border border-gray-200 text-red-500">含まない</td>
              <td class="p-3 border border-gray-200 text-red-500">含まない</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <CTASection />
</BaseLayout>
