---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import { services } from '../content/services';

const differentiators = [
  { icon: '⚡', title: '短期納品', description: 'テンプレートベースで2〜4週間を目安に動くものを届けます。' },
  { icon: '💰', title: '低コスト', description: 'PoCに必要な最小構成に絞ることで、コストを抑えます。' },
  { icon: '📦', title: 'テンプレート活用', description: '用途別テンプレートを活用し、車輪の再発明をしません。' },
  { icon: '🎯', title: 'スコープ明確', description: '保守・無制限修正は含まず、最初から範囲を明示します。' },
];
---

<BaseLayout>
  <!-- Hero -->
  <section class="bg-gray-900 text-white">
    <div class="max-w-5xl mx-auto px-4 py-20 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 leading-tight">
        小規模DXの第一歩を、<br />短期・低コストで。
      </h1>
      <p class="text-gray-300 text-lg md:text-xl mb-8 max-w-2xl mx-auto">
        BysonTechは、PoCに特化した開発サービスとテンプレートを提供します。<br class="hidden md:inline" />
        まず動くものを作り、DX推進の手がかりをつかみましょう。
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/services/" class="bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-3 rounded-lg transition-colors">
          サービスを見る
        </a>
        <a href="/contact/" class="border border-gray-400 hover:border-white text-gray-200 hover:text-white font-medium px-6 py-3 rounded-lg transition-colors">
          相談する
        </a>
      </div>
    </div>
  </section>

  <!-- Services overview -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <h2 class="text-2xl font-bold text-center mb-2">提供サービス</h2>
    <p class="text-center text-gray-500 mb-10">2つの形態でPoC推進を支援します</p>
    <div class="grid md:grid-cols-2 gap-6">
      {services.map((service) => (
        <div class="border border-gray-200 rounded-xl p-6 hover:shadow-md transition-shadow">
          <h3 class="text-lg font-bold mb-2">{service.name}</h3>
          <p class="text-gray-600 text-sm mb-4">{service.summary}</p>
          <p class="text-blue-600 font-medium text-sm">{service.priceRange}</p>
          <a href="/services/" class="inline-block mt-4 text-sm text-blue-600 hover:underline">
            詳細を見る →
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- Differentiators -->
  <section class="bg-gray-50 border-y border-gray-200">
    <div class="max-w-5xl mx-auto px-4 py-14">
      <h2 class="text-2xl font-bold text-center mb-10">BysonTech の特徴</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {differentiators.map((item) => (
          <div class="text-center">
            <div class="text-3xl mb-3">{item.icon}</div>
            <h3 class="font-bold mb-1">{item.title}</h3>
            <p class="text-gray-500 text-sm">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
