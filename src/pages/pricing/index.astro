---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import { pricingPlans, disclaimer } from '../../content/pricing';

const pageTitle = '料金';
const pageDescription =
  'BysonTechの料金プラン一覧。テンプレートプラン・PoC開発プラン・カスタム相談の3つからお選びください。';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="max-w-5xl mx-auto px-4 py-14">
    <h1 class="text-3xl font-bold mb-2">料金</h1>
    <p class="text-gray-500 mb-12">すべて目安金額（税別）です。最終価格は個別見積もりにてご案内します。</p>

    <!-- Plan cards -->
    <div class="grid md:grid-cols-3 gap-6 mb-14">
      {
        pricingPlans.map((plan) => (
          <div
            class={`rounded-xl p-6 flex flex-col border ${
              plan.recommended
                ? 'border-blue-500 bg-blue-50 shadow-md'
                : 'border-gray-200 bg-white'
            }`}
          >
            {plan.recommended && (
              <span class="text-xs font-bold text-blue-600 uppercase mb-2">おすすめ</span>
            )}
            <h2 class="text-lg font-bold mb-1">{plan.planName}</h2>
            <p class="text-3xl font-bold text-gray-900 my-3">{plan.price}</p>
            <p class="text-xs text-gray-400 mb-5">{plan.priceNote}</p>

            <div class="flex-1">
              <h3 class="text-sm font-bold text-gray-600 mb-2">含まれるもの</h3>
              <ul class="space-y-1 mb-5">
                {plan.features.map((f) => (
                  <li class="text-sm text-gray-700 flex gap-2">
                    <span class="text-green-500 mt-0.5">✓</span>
                    {f}
                  </li>
                ))}
              </ul>

              <h3 class="text-sm font-bold text-gray-400 mb-2">含まれないもの</h3>
              <ul class="space-y-1">
                {plan.notIncluded.map((f) => (
                  <li class="text-sm text-gray-400 flex gap-2">
                    <span class="mt-0.5">—</span>
                    {f}
                  </li>
                ))}
              </ul>
            </div>

            <a
              href="/contact/"
              class={`mt-6 block text-center py-2 px-4 rounded-lg font-medium text-sm transition-colors ${
                plan.recommended
                  ? 'bg-blue-600 text-white hover:bg-blue-700'
                  : 'border border-gray-300 text-gray-700 hover:bg-gray-50'
              }`}
            >
              相談する
            </a>
          </div>
        ))
      }
    </div>

    <!-- Disclaimer -->
    <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-5">
      <h3 class="font-bold text-yellow-800 mb-2">ご注意・免責事項</h3>
      <p class="text-sm text-yellow-700 whitespace-pre-line">{disclaimer}</p>
    </div>
  </div>

  <CTASection
    title="プランについて詳しく相談する"
    description="ご不明な点や内容確認は、お問い合わせください。"
  />
</BaseLayout>
