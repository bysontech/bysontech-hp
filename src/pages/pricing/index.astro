---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import { plans, pricingNote } from '../../content/pricing';
---

<BaseLayout title="料金" description="BysonTechの料金プラン一覧です。プロジェクト規模に応じたプランをご用意しています。">
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4">
      <h1 class="text-3xl font-bold mb-4">料金</h1>
      <p class="text-gray-600 mb-12">
        プロジェクト規模や要件に応じたプランをご用意しています。詳細はお問い合わせください。
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        {plans.map((plan) => (
          <div class={`border rounded-lg p-8 flex flex-col gap-4 ${plan.highlighted ? 'border-blue-500 shadow-md' : 'border-gray-200'}`}>
            {plan.highlighted && (
              <span class="text-xs font-semibold text-blue-600 uppercase tracking-wide">おすすめ</span>
            )}
            <h2 class="text-xl font-bold">{plan.name}</h2>
            <p class="text-2xl font-semibold text-gray-800">{plan.price}</p>
            <p class="text-gray-600 text-sm">{plan.description}</p>
            <ul class="flex flex-col gap-2 flex-1">
              {plan.features.map((f) => (
                <li class="flex items-start gap-2 text-sm text-gray-700">
                  <span class="text-blue-600 mt-0.5">✓</span>
                  {f}
                </li>
              ))}
            </ul>
            <a
              href={plan.cta.href}
              class={`mt-2 text-center font-semibold px-6 py-2 rounded transition-colors ${plan.highlighted ? 'bg-blue-600 text-white hover:bg-blue-700' : 'border border-gray-300 text-gray-700 hover:bg-gray-50'}`}
            >
              {plan.cta.label}
            </a>
          </div>
        ))}
      </div>

      <p class="text-sm text-gray-500">{pricingNote}</p>
    </div>
  </section>

  <CTASection />
</BaseLayout>
