---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import { faqs } from '../../content/faq';
---

<BaseLayout title="FAQ" description="BysonTechへのよくあるご質問と回答をまとめています。">
  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-3xl font-bold mb-4">よくある質問</h1>
      <p class="text-gray-600 mb-12">お客様からよくいただくご質問をまとめています。</p>

      <div class="flex flex-col gap-3">
        {faqs.map((faq) => (
          <details class="border border-gray-200 rounded-lg group">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer font-medium text-gray-900 hover:bg-gray-50 select-none list-none">
              <span>{faq.question}</span>
              <span class="ml-4 text-gray-400 transition-transform group-open:rotate-180 shrink-0">▼</span>
            </summary>
            <div class="px-6 pb-5 text-gray-600 text-sm leading-relaxed border-t border-gray-100 pt-4">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTASection title="解決しない場合はお気軽に" description="FAQに載っていないご質問もお気軽にお問い合わせください。" />
</BaseLayout>
