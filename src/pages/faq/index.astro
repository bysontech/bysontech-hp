---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import { faqItems, faqCategories } from '../../content/faq';

const pageTitle = 'FAQ';
const pageDescription =
  'BysonTechのよくある質問。サービス全般、PoC開発、テンプレート、契約・支払いについてまとめています。';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="max-w-3xl mx-auto px-4 py-14">
    <h1 class="text-3xl font-bold mb-2">よくある質問</h1>
    <p class="text-gray-500 mb-12">
      ご不明な点が解決しない場合は<a href="/contact/" class="text-blue-600 hover:underline">お問い合わせ</a>ください。
    </p>

    {
      faqCategories.map((category) => (
        <section class="mb-12">
          <h2 class="text-xl font-bold mb-4 pb-2 border-b border-gray-200">{category}</h2>
          <div class="space-y-3">
            {faqItems
              .filter((item) => item.category === category)
              .map((item) => (
                <details class="border border-gray-200 rounded-xl group">
                  <summary class="flex items-center justify-between p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50 rounded-xl list-none">
                    <span>{item.question}</span>
                    <svg
                      class="w-5 h-5 text-gray-400 shrink-0 ml-2 transition-transform group-open:rotate-180"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </summary>
                  <div class="px-4 pb-4 text-sm text-gray-600 leading-relaxed">
                    {item.answer}
                  </div>
                </details>
              ))}
          </div>
        </section>
      ))
    }
  </div>

  <CTASection
    title="解決しない場合はお気軽に"
    description="FAQに掲載されていない質問もお受けしています。"
  />
</BaseLayout>
