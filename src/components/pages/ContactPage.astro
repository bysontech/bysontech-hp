---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getContactContent } from '../../lib/content';
import type { Locale } from '../../lib/i18n';

const locale = (Astro.currentLocale ?? 'en') as Locale;
const { methods, note } = getContactContent(locale);

const ui =
  locale === 'en'
    ? {
        title: 'Contact',
        description: 'Get in touch with BysonTech via email, Upwork, or LinkedIn.',
        heading: 'Get in touch',
        sub: "Rough requirements are fine — just tell us what you're trying to solve and we'll figure out the scope together.",
        externalIcon: true,
      }
    : {
        title: 'お問い合わせ',
        description: 'BysonTechへのお問い合わせ。メール・Upwork・LinkedInからご連絡ください。',
        heading: 'お問い合わせ',
        sub: '要件が固まっていなくてもOKです。課題感だけでもお気軽にどうぞ。',
        externalIcon: true,
      };
---

<BaseLayout title={ui.title} description={ui.description}>
  <div class="max-w-2xl mx-auto px-4 py-14">
    <h1 class="text-3xl font-bold mb-2">{ui.heading}</h1>
    <p class="text-gray-500 mb-10 leading-relaxed">{ui.sub}</p>

    <div class="space-y-4 mb-10">
      {
        methods.map((method) => (
          <a
            href={method.url}
            target={method.external ? '_blank' : undefined}
            rel={method.external ? 'noopener noreferrer' : undefined}
            class="flex items-start gap-4 p-5 border border-gray-200 rounded-xl hover:border-blue-400 hover:shadow-sm transition-all group"
          >
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="font-semibold text-gray-800 group-hover:text-blue-600 transition-colors">{method.label}</span>
                {method.external && (
                  <svg class="w-3.5 h-3.5 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                )}
              </div>
              <p class="text-sm text-gray-500 leading-relaxed">{method.description}</p>
            </div>
            <svg class="w-5 h-5 text-gray-300 group-hover:text-blue-400 self-center shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ))
      }
    </div>

    <p class="text-xs text-gray-400 bg-gray-50 rounded-lg p-4 leading-relaxed">{note}</p>
  </div>
</BaseLayout>
