---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../CTASection.astro';
import { getServicesContent } from '../../lib/content';
import type { Locale } from '../../lib/i18n';

const locale = (Astro.currentLocale ?? 'en') as Locale;
const services = getServicesContent(locale);

const ui =
  locale === 'en'
    ? {
        title: 'Services',
        description: 'Two service models to help small businesses move fast on DX — from full PoC development to self-serve templates.',
        intro: 'BysonTech offers two delivery models. Choose based on your technical capacity and budget.',
        targetCustomerLabel: 'Who it\'s for',
        deliverablesLabel: 'What you get',
        fitForLabel: 'Good fit if',
        notFitForLabel: 'Not a fit if',
        priceLabel: 'Starting from',
        comparisonHeading: 'Side-by-side comparison',
        comparisonRows: [
          { label: 'Price', key: 'priceRange' as const },
        ],
        comparisonExtra: [
          { label: 'Technical skill required', values: ['None (we build it)', 'Some (self-serve)'] },
          { label: 'Customization', values: ['Scoped per requirements', 'Limited (quoted separately)'] },
          { label: 'Maintenance included', values: ['No', 'No'] },
        ],
      }
    : {
        title: 'サービス',
        description: 'BysonTechが提供する2つのサービス：小規模DX向けPoC開発とPoCテンプレート販売の詳細をご覧ください。',
        intro: 'BysonTechは「PoC開発」と「テンプレート販売」の2つの形態でDX支援を行います。技術力と予算に応じてお選びください。',
        targetCustomerLabel: '対象顧客',
        deliverablesLabel: '提供内容',
        fitForLabel: '向いている人',
        notFitForLabel: '向いていない人',
        priceLabel: '価格帯',
        comparisonHeading: 'サービス比較',
        comparisonRows: [
          { label: '価格帯', key: 'priceRange' as const },
        ],
        comparisonExtra: [
          { label: '技術力の要件', values: ['不要（お任せ）', 'ある程度必要'] },
          { label: 'カスタマイズ', values: ['要件に応じて実装', '限定対応（別途見積）'] },
          { label: '保守・運用', values: ['含まない', '含まない'] },
        ],
      };
---

<BaseLayout title={ui.title} description={ui.description}>
  <div class="max-w-5xl mx-auto px-4 py-14">
    <h1 class="text-3xl font-bold mb-2">{ui.title}</h1>
    <p class="text-gray-500 mb-12">{ui.intro}</p>

    {
      services.map((service) => (
        <section id={service.id} class="mb-16 scroll-mt-24">
          <h2 class="text-2xl font-bold mb-2">{service.name}</h2>
          <p class="text-gray-600 leading-relaxed mb-8">{service.summary}</p>

          <div class="grid md:grid-cols-2 gap-5 mb-5">
            <div class="bg-gray-50 rounded-xl p-5">
              <h3 class="font-semibold text-xs uppercase tracking-wide text-gray-400 mb-3">{ui.targetCustomerLabel}</h3>
              <ul class="space-y-1.5">
                {service.targetCustomer.map((item) => (
                  <li class="text-sm text-gray-700 flex gap-2">
                    <span class="text-blue-400 mt-0.5 shrink-0">•</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div class="bg-gray-50 rounded-xl p-5">
              <h3 class="font-semibold text-xs uppercase tracking-wide text-gray-400 mb-3">{ui.deliverablesLabel}</h3>
              <ul class="space-y-1.5">
                {service.deliverables.map((item) => (
                  <li class="text-sm text-gray-700 flex gap-2">
                    <span class="text-green-500 mt-0.5 shrink-0">✓</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-5 mb-5">
            <div class="border border-green-200 rounded-xl p-5">
              <h3 class="font-semibold text-green-700 mb-3">{ui.fitForLabel}</h3>
              <ul class="space-y-1.5">
                {service.fitFor.map((item) => (
                  <li class="text-sm text-gray-700 flex gap-2">
                    <span class="text-green-500 mt-0.5 shrink-0">○</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div class="border border-red-200 rounded-xl p-5">
              <h3 class="font-semibold text-red-600 mb-3">{ui.notFitForLabel}</h3>
              <ul class="space-y-1.5">
                {service.notFitFor.map((item) => (
                  <li class="text-sm text-gray-700 flex gap-2">
                    <span class="text-red-400 mt-0.5 shrink-0">✕</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <div class="inline-flex items-center gap-2 bg-blue-50 border border-blue-100 rounded-xl px-5 py-3">
            <span class="text-sm text-gray-500">{ui.priceLabel}:</span>
            <span class="font-bold text-blue-700">{service.priceRange}</span>
          </div>
        </section>
      ))
    }

    <!-- Comparison table -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">{ui.comparisonHeading}</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-gray-100">
              <th class="text-left p-3 border border-gray-200 w-1/3"></th>
              {services.map((s) => (
                <th class="text-left p-3 border border-gray-200 font-semibold">{s.name}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {ui.comparisonRows.map((row) => (
              <tr>
                <td class="p-3 border border-gray-200 text-gray-500">{row.label}</td>
                {services.map((s) => (
                  <td class="p-3 border border-gray-200">{s[row.key]}</td>
                ))}
              </tr>
            ))}
            {ui.comparisonExtra.map((row, i) => (
              <tr class={i % 2 === 0 ? 'bg-gray-50' : ''}>
                <td class="p-3 border border-gray-200 text-gray-500">{row.label}</td>
                {row.values.map((v) => (
                  <td class="p-3 border border-gray-200">{v}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <CTASection />
</BaseLayout>
