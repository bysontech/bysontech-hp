---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../CTASection.astro';
import { getPricingContent } from '../../lib/content';
import type { Locale } from '../../lib/i18n';

const locale = (Astro.currentLocale ?? 'en') as Locale;
const { plans, disclaimer } = getPricingContent(locale);

const ui =
  locale === 'en'
    ? {
        title: 'Pricing',
        description: 'BysonTech pricing plans — Template, PoC Development, and Custom Quote.',
        subtitle: 'All prices are estimates, excluding tax. Final amounts confirmed via individual quotation.',
        includedLabel: "What's included",
        notIncludedLabel: 'Not included',
        recommendedBadge: 'Recommended',
        ctaLabel: 'Get a quote',
        disclaimerHeading: 'Important notes',
        ctaSectionTitle: 'Not sure which plan fits?',
        ctaSectionDesc: "Tell us what you're trying to build and we'll recommend the right approach.",
      }
    : {
        title: '料金',
        description: 'BysonTechの料金プラン一覧。テンプレートプラン・PoC開発プラン・カスタム相談の3つからお選びください。',
        subtitle: 'すべて目安金額（税別）です。最終価格は個別見積もりにてご案内します。',
        includedLabel: '含まれるもの',
        notIncludedLabel: '含まれないもの',
        recommendedBadge: 'おすすめ',
        ctaLabel: '相談する',
        disclaimerHeading: 'ご注意・免責事項',
        ctaSectionTitle: 'どのプランか迷っている方へ',
        ctaSectionDesc: '内容をお気軽にご相談ください。最適なプランをご提案します。',
      };

const contactHref = locale === 'en' ? '/contact/' : '/ja/contact/';
---

<BaseLayout title={ui.title} description={ui.description}>
  <div class="max-w-5xl mx-auto px-4 py-14">
    <h1 class="text-3xl font-bold mb-2">{ui.title}</h1>
    <p class="text-gray-500 mb-12">{ui.subtitle}</p>

    <!-- Plan cards -->
    <div class="grid md:grid-cols-3 gap-6 mb-14">
      {
        plans.map((plan) => (
          <div
            class={`rounded-xl p-6 flex flex-col border ${
              plan.recommended
                ? 'border-blue-500 bg-blue-50 shadow-md'
                : 'border-gray-200 bg-white'
            }`}
          >
            {plan.recommended && (
              <span class="text-xs font-bold text-blue-600 uppercase tracking-wide mb-2">{ui.recommendedBadge}</span>
            )}
            <h2 class="text-lg font-bold mb-1">{plan.planName}</h2>
            <p class="text-3xl font-bold text-gray-900 my-3">{plan.price}</p>
            <p class="text-xs text-gray-400 mb-6 leading-relaxed">{plan.priceNote}</p>

            <div class="flex-1">
              <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-2">{ui.includedLabel}</h3>
              <ul class="space-y-1.5 mb-5">
                {plan.features.map((f) => (
                  <li class="text-sm text-gray-700 flex gap-2">
                    <span class="text-green-500 mt-0.5 shrink-0">✓</span>
                    {f}
                  </li>
                ))}
              </ul>

              <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-2">{ui.notIncludedLabel}</h3>
              <ul class="space-y-1.5">
                {plan.notIncluded.map((f) => (
                  <li class="text-sm text-gray-400 flex gap-2">
                    <span class="mt-0.5 shrink-0">—</span>
                    {f}
                  </li>
                ))}
              </ul>
            </div>

            <a
              href={contactHref}
              class={`mt-6 block text-center py-2.5 px-4 rounded-lg font-medium text-sm transition-colors ${
                plan.recommended
                  ? 'bg-blue-600 text-white hover:bg-blue-700'
                  : 'border border-gray-300 text-gray-700 hover:bg-gray-50'
              }`}
            >
              {ui.ctaLabel}
            </a>
          </div>
        ))
      }
    </div>

    <!-- Disclaimer -->
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-5">
      <h3 class="font-semibold text-amber-800 mb-2">{ui.disclaimerHeading}</h3>
      <p class="text-sm text-amber-700 whitespace-pre-line leading-relaxed">{disclaimer}</p>
    </div>
  </div>

  <CTASection title={ui.ctaSectionTitle} description={ui.ctaSectionDesc} />
</BaseLayout>
